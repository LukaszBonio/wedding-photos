# Skopiuj ten plik do .env.local i uzupełnij wartości.
# UWAGA: obie wartości i tak trafiają do publicznego bundle'a przeglądarki.
# Token to warstwa odsiewająca spam, NIE pełne zabezpieczenie (patrz README).

# URL Web App Google Apps Script (kończy się na /exec)
VITE_GAS_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXX/exec

# Statyczny token uploadu (identyczny z UPLOAD_TOKEN w Script Properties)
VITE_UPLOAD_TOKEN=zmien-mnie-na-dlugi-losowy-ciag
